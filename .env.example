# ============================================================
# BalanceBuddy AI configuration
# ============================================================
#
# IMPORTANT: KHÔNG để comment (#...) trên CÙNG dòng với value rỗng.
# python-dotenv sẽ đọc nguyên comment thành value. Để comment trên dòng
# RIÊNG (như file này).


# ===== Model =====
# App tự tìm file *.gguf đầu tiên trong ./models/.
# Để chỉ định cụ thể file (khi có nhiều .gguf), uncomment:
MODEL_FILE=Qwen_Qwen3-14B-Q4_K_M.gguf

# ===== Inference =====
# Context window (tokens)
N_CTX=8192

# GPU layers: 0 = chỉ CPU. -1 = đẩy hết lên GPU (cần CUDA/Metal build).
N_GPU_LAYERS=0

# Số CPU threads. Để trống = auto.
N_THREADS=

# Max tokens cho mỗi lần sinh.
MAX_OUTPUT_TOKENS=2048


# ===== OCR (cho ảnh) =====
OCR_LANGS=vie+eng


# ===== Dev / Misc =====
# MOCK_LLM=1: bỏ qua model, trả response giả (test UI).
MOCK_LLM=0

# PRELOAD_MODEL=0: không load model ngay khi khởi động.
PRELOAD_MODEL=1
